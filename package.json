{
  "name": "flexdb-node",
  "version": "0.1.0",
  "description": "Official Node.js client for FlexDB — zero-dependency, TypeScript-first.",
  "keywords": ["flexdb", "database", "sqlite", "raft", "distributed", "client"],
  "homepage": "https://github.com/tychoish/flexdb-node#readme",
  "license": "MIT",
  "author": "Tycho Andersen",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "build": "tsc --project tsconfig.build.json",
    "build:watch": "tsc --project tsconfig.build.json --watch",
    "clean": "rm -rf dist",
    "prebuild": "npm run clean",
    "test:unit": "node --import tsx/esm --test tests/unit/**/*.test.ts",
    "test:integration": "node --import tsx/esm --test tests/integration/**/*.test.ts",
    "test": "npm run test:unit",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build && npm run typecheck"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  }
}
